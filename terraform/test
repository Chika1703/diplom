# 1.1 Обновляем ОС
sudo apt update && sudo apt -y upgrade

# 1.2 Устанавливаем базовые пакеты
sudo apt -y install ca-certificates curl gnupg lsb-release apt-transport-https

# 1.3 Отключаем swap (kubeadm требует отключенного swap)
sudo swapoff -a
# Закомментировать swap в /etc/fstab чтобы при перезагрузке не включался:
sudo sed -i.bak -E 's@(^([^#].*swap.*)$)@#\1@g' /etc/fstab

# 1.4 Включаем пересылку и нужные опции ядра для сетевых плагинов
cat <<'EOF' | sudo tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.ipv4.ip_forward                 = 1
net.bridge.bridge-nf-call-ip6tables = 1
EOF
sudo sysctl --system

# 2.1 Установка containerd
sudo apt update
sudo apt -y install containerd

# 2.2 Создаём конфиг containerd и включаем systemd cgroup (важно для kubelet)
sudo mkdir -p /etc/containerd
sudo containerd config default | sudo tee /etc/containerd/config.toml

# правим SystemdCgroup в нужном месте (sed меняет экранно; убедитесь, что строка существует)
sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml

# 2.3 Перезапуск containerd
sudo systemctl restart containerd
sudo systemctl enable containerd

# 3.1 Добавляем GPG и репозиторий Kubernetes
curl -fsSLo /usr/share/keyrings/kubernetes-archive-keyring.asc \
  https://pkgs.k8s.io/core:/stable:/v1.30/deb/Release.key

echo "deb [signed-by=/usr/share/keyrings/kubernetes-archive-keyring.asc] \
  https://pkgs.k8s.io/core:/stable:/v1.30/deb/ /" \
  | sudo tee /etc/apt/sources.list.d/kubernetes.list

sudo apt-get update


# 3.2 Устанавливаем конкретные пакеты (без автоматического обновления)
sudo apt-get install -y kubeadm kubelet kubectl
sudo apt-mark hold kubeadm kubelet kubectl

# На master (если используется UFW)
sudo apt install ufw

sudo ufw allow 6443/tcp
sudo ufw allow 2379:2380/tcp
sudo ufw allow 10250/tcp
sudo ufw allow 10251/tcp
sudo ufw allow 10252/tcp

# На воркерах (если UFW)
sudo apt install ufw
sudo ufw allow 10250/tcp
# (и если используете NodePort/hostPort/ingress — откройте нужные)


